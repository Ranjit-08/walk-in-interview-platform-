# ── Python ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Environment files (NEVER commit these) ─────────────────────────
.env
.env.local
.env.production
backend/.env

# ── Terraform ──────────────────────────────────────────────────────
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfplan
terraform/terraform.tfvars        # Contains secrets

# ── AWS ────────────────────────────────────────────────────────────
*.pem
*.key

# ── IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ───────────────────────────────────────────────────────────
*.log
logs/

# ── Node (if any tooling added later) ──────────────────────────────
node_modules/
npm-debug.log
```

---

### Full CI/CD Flow Diagram
```
Developer pushes to main
        │
        ├─── backend/** changed?
        │         │
        │    deploy-backend.yml
        │         │
        │    ┌────▼─────┐
        │    │  Run      │
        │    │  Tests    │ ← MySQL service container
        │    └────┬─────┘
        │         │ pass
        │    ┌────▼──────────┐
        │    │  SSH into EC2  │
        │    │  git pull      │
        │    │  pip install   │
        │    │  supervisorctl │
        │    │  restart       │
        │    └────┬──────────┘
        │         │
        │    Health check /health
        │
        └─── frontend/** changed?
                  │
           deploy-frontend.yml
                  │
           ┌──────▼──────┐
           │  Validate    │
           │  HTML files  │
           └──────┬───────┘
                  │ pass
           ┌──────▼───────────────┐
           │  Inject API_BASE URL  │
           │  aws s3 sync          │
           │  Set cache headers    │
           └──────┬───────────────┘
                  │
           Verify S3 website URL